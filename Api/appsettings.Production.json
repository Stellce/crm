{
  "FileStorage": {
    "RootPath": "/home/crm-uploads",
    "MaxFileSizeBytes": 5242880,
    "AllowedExtensions": [ ".pdf", ".png", ".jpg", ".jpeg" ]
  },
  "Auth": {
    "AccessTokenLifetime": "00:10:00",
    "RefreshTokenLifetime": "01:00:00",
    "TokenClockSkew": "00:00:30"
  },
  "PasswordReset": {
    "FrontendBaseUrl": "https://crm-stellce.azurewebsites.net",
    "TokenLifetime": "00:30:00"
  },
  "Email": {
    "Smtp": {
      "Enabled": false
    }
  },
  "RateLimiting": {
    "Auth": {
      "PermitLimit": 5,
      "Window": "00:05:00",
      "QueueLimit": 0
    },
    "UserApi": {
      "PermitLimit": 60,
      "Window": "00:01:00",
      "SegmentsPerWindow": 6,
      "QueueLimit": 0
    }
  }
}